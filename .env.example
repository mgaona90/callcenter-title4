# ─────────────────────────────────────────────
# Anthropic
# ─────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─────────────────────────────────────────────
# VAPI  (https://vapi.ai)
# ─────────────────────────────────────────────
VAPI_API_KEY=...
# Secret used to verify VAPI webhook signatures
VAPI_WEBHOOK_SECRET=...
# Phone number ID used for outbound (optional)
VAPI_PHONE_NUMBER_ID=...

# ─────────────────────────────────────────────
# Langfuse  (https://cloud.langfuse.com)
# ─────────────────────────────────────────────
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_HOST=https://cloud.langfuse.com

# ─────────────────────────────────────────────
# Cohere  (reranker — https://cohere.com)
# ─────────────────────────────────────────────
COHERE_API_KEY=...

# ─────────────────────────────────────────────
# Qdrant (vector DB)
# ─────────────────────────────────────────────
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=title4_knowledge

# ─────────────────────────────────────────────
# Redis (session memory)
# ─────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ─────────────────────────────────────────────
# LLM model routing
# ─────────────────────────────────────────────
# Tier 1 (simple FAQ) — fast, low cost
LLM_MODEL_TIER1=claude-haiku-4-5-20251001
# Tier 2 (complex regulatory) — most capable
LLM_MODEL_TIER2=claude-opus-4-8
# Query classifier — fast classification
LLM_MODEL_CLASSIFIER=claude-haiku-4-5-20251001

# ─────────────────────────────────────────────
# App settings
# ─────────────────────────────────────────────
BACKEND_URL=http://backend:8000
# Maximum conversation turns stored in Redis per call
MAX_CONTEXT_TURNS=10
# Confidence threshold below which a disclaimer is injected
CONFIDENCE_DISCLAIMER_THRESHOLD=0.72
DEBUG=false
